#!/bin/bash
# 全套：单元 + 集成 + 覆盖率校验
set -euo pipefail

echo "Running pre-push checks..."

cd "$(git rev-parse --show-toplevel)"

# 后端（子 shell 隔离 cd）
( cd backend && uv run pytest ../tests/unit/backend/ ../tests/dev-integration/backend/ \
    --cov=app --cov-report=term-missing --cov-fail-under=80 )

# 前端
( cd frontend && pnpm test:unit )
( cd frontend && pnpm test:integration )

echo "Pre-push checks passed!"
