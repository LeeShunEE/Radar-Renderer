#!/bin/bash
# 全套：单元 + 集成 + 覆盖率校验

echo "Running pre-push checks..."

# 后端
cd backend && uv run pytest ../tests/unit/backend/ ../tests/dev-integration/backend/ -v --cov=app --cov-report=term-missing --cov-fail-under=80

# 前端
cd frontend && pnpm test:unit --run --coverage
cd frontend && pnpm test:integration --run

echo "Pre-push checks passed!"