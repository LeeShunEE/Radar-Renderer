# 后端环境变量模板。复制为 backend/.env 并填入真实值（.env 不进 git，仅本地开发用）。
# 优先级：环境变量 > .env > 字段默认值。
# 生产/testenv 的连接配置由部署系统或测试系统通过环境变量注入（见 CLAUDE.md §3.3.1），不要写进仓库。

# ============================================================
# 数据库连接串
#   dev:  sqlite+aiosqlite:///./data.db
#   prod: postgresql+asyncpg://user:pass@host:5432/dbname
# ============================================================
DATABASE_URL=sqlite+aiosqlite:///./data.db

# ============================================================
# API / CORS
# ============================================================
API_PREFIX=/api/v1
# list[str]：直接写 JSON 数组形式，pydantic-settings 原生解析
CORS_ORIGINS=["http://localhost:3000"]

# ============================================================
# 鉴权（生产务必改 JWT_SECRET_STRING 为长随机串）
# ============================================================
JWT_SECRET_STRING=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440          # access token 有效期（分钟）
JWT_REFRESH_EXPIRE_MINUTES=10080 # refresh token 有效期（分钟）

# ============================================================
# 验证码
# ============================================================
VERIFICATION_CODE_EXPIRE_MINUTES=10
VERIFICATION_CODE_LENGTH=6
VERIFICATION_CODE_COOLDOWN_SECONDS=60

# ============================================================
# Resend 邮件服务（可选）
# ============================================================
# RESEND_API_KEY_SECRET_STRING=

# ============================================================
# OAuth（可选；任一 provider 不配置 CLIENT_ID，前端将自动隐藏其登录按钮）
#
# redirect_uri 必须指向【前端回调路由】 /auth/callback/{provider}，
# 且与 provider 后台（Google Cloud Console / GitHub Developer Settings）填写的
# 「授权回调地址」完全一致。下例为本地 deploy（前端 13000 端口）。
# ============================================================
# Google：Google Cloud Console → API 和服务 → 凭据 → 创建 OAuth 2.0 客户端 ID
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET_SECRET_STRING=
# OAUTH_GOOGLE_REDIRECT_URI=http://localhost:13000/auth/callback/google

# GitHub：GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET_SECRET_STRING=
# OAUTH_GITHUB_REDIRECT_URI=http://localhost:13000/auth/callback/github

# ============================================================
# 文件存储
# ============================================================
STORAGE_ROOT=./storage
MAX_USER_STORAGE_BYTES=209715200 # 单用户配额上限（字节），默认 200 MiB

# ============================================================
# 渲染旋钮
# ============================================================
RENDER_CONCURRENCY=2                  # 服务端渲染固定并发数
WORKER_BASE_URL=http://localhost:3100
RENDER_TIMEOUT_SECONDS=600
