# 部署环境变量模板。复制为 deploy/.env 并填入真实值（.env 不进 git）。
# 这些变量被 deploy/docker-compose.yml 中的 ${VAR:-默认} 占位引用，
# Coolify 部署时可改为在 Coolify UI 注入同名环境变量，无需维护 .env 文件。
# 优先级：环境变量 > .env > compose 内默认值。

# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_USER=radar
# 必填：强密码
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=radar_chart

# ============================================================
# 后端（FastAPI）
# ============================================================
# 必填：长随机串（≥32 字符）
JWT_SECRET_STRING=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
JWT_REFRESH_EXPIRE_MINUTES=10080

# list[str]：JSON 数组形式，compose 会透传给后端 CORS_ORIGINS
CORS_ORIGINS=["http://localhost:3000"]

# 对外 API 地址（前端运行时通过 NEXT_PUBLIC_API_URL 访问后端）
API_PUBLIC_URL=http://localhost:8000

# 渲染旋钮
RENDER_CONCURRENCY=2
RENDER_TIMEOUT_SECONDS=600

# 必填（生产）：backend ↔ render-worker 进度回调共享密钥（≥32 字符随机串）。
# 非用户态鉴权，用于防止公网伪造渲染进度回调。compose 会同时注入到 backend
# 的 RENDER_CALLBACK_TOKEN_SECRET_STRING 与 render-worker 的 RENDER_CALLBACK_TOKEN，
# 两侧必须同值。不填则退回 dev-only 默认值（生产不安全）。
RENDER_CALLBACK_TOKEN=change-me-to-a-long-random-string

# ============================================================
# OAuth（可选；任一 provider 不配置 CLIENT_ID，前端将自动隐藏其登录按钮）
# redirect_uri 必须指向前端回调路由 /auth/callback/{provider}，
# 与 provider 后台「授权回调地址」完全一致。
# ============================================================
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:13000/auth/callback/google
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URI=http://localhost:13000/auth/callback/github

# Resend 邮件服务（可选）
RESEND_API_KEY=
# 发件人地址；不配走 Resend 测试发件人。用真实域名前需在 Resend 后台完成域名验证。
RESEND_FROM_EMAIL=onboarding@resend.dev

# ============================================================
# 资源限制（compose v2 单机语义；不填走默认）
# ============================================================
# 后端服务
BACKEND_MEMORY_LIMIT=1g
BACKEND_CPUS=1.0
# 前端服务（生产 next start 内存稳定；dev override 默认放宽到 2g）
FRONTEND_MEMORY_LIMIT=512m
# 渲染工作器（吃内存，默认给大些）
RENDER_WORKER_MEMORY_LIMIT=2g
RENDER_WORKER_CPUS=2.0
# 数据库
DB_MEMORY_LIMIT=512m
